# Public base URL. Used for canonical, OG, sitemap, robots.
# In Vercel prod env: set to https://lasahtx.com
# In preview/dev: leave unset; VERCEL_URL / localhost fallback in lib/site.ts.
NEXT_PUBLIC_SITE_URL=

# Resend transactional email (catering inquiry forms land in a later session).
RESEND_API_KEY=
# Where form submissions are emailed.
CONTACT_EMAIL_TO=

# Pop-ups waitlist provider — Beehiiv / ConvertKit / Mailchimp, TBD.
WAITLIST_PROVIDER_API_KEY=
WAITLIST_PROVIDER_LIST_ID=
